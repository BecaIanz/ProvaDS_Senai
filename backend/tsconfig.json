{
  "$schema": "https://www.schemastore.org/tsconfig",

  "compilerOptions": {
    "target": "",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2024"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "allowImportingTsExtensions": true,
    "noEmit": true
  },
}